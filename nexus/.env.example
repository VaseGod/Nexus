# ===========================================
# NEXUS Environment Configuration
# ===========================================

# --- LLM Provider Keys ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# --- Edge Model ---
EDGE_MODEL_PATH=/models/ternary-1bit.gguf
ULTRAPLAN_THRESHOLD=0.4

# --- Memory ---
MEMORY_BASE_PATH=./memory
LANCEDB_PATH=./memory/vectors

# --- Server ---
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production

# --- Compaction Worker ---
COMPACTION_INTERVAL_MINUTES=30
COMPACTION_WORKER_URL=http://compaction-worker:8001

# --- Aurora Speculative Decoding ---
AURORA_CONTROLLER_URL=http://aurora-controller:8002
DRAFT_MODEL_PATH=/models/draft-model.gguf
TARGET_MODEL_PATH=/models/target-model.gguf
AURORA_DRAFT_K=5
AURORA_TRAINING_INTERVAL=500

# --- Edge Server ---
EDGE_SERVER_URL=http://edge-server:8003

# --- Daemon ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxx

# --- AWS (for Pulumi / production) ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# --- Database ---
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-east-1
